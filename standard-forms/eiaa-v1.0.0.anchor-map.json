  "coverage_exempt_rationales": {
    "sec-preamble": "Preamble identifies the parties and agreement purpose. It carries no reviewable legal clause — counterparty changes here are de minimis (name/address/date corrections). No topic is needed.",
    "sec-signature": "Signature block identifies signatories and execution date. It carries no reviewable legal clause — counterparty changes are de minimis. No topic is needed.",
    "sec-1": "Section 1 ('Student Training Program') is a structural parent heading that groups §1.1–§1.7. It contains no standalone reviewable legal clause — all substantive obligations are expressed in the numbered sub-sections, each of which has a dedicated topic. No additional topic is needed for the parent heading.",
    "sec-1.1": "Section 1.1 ('General Obligations') is an introductory subsection that summarises the §1 block at a high level. It does not introduce obligations beyond those detailed in §1.2–§1.7, which are individually covered by playbook topics. No additional topic is needed.",
    "sec-2.2": "Section 2.2 ('Termination') is a structural parent heading that groups §2.2.1 and §2.2.2. It contains no standalone reviewable legal clause — all substantive termination mechanics are in the numbered sub-sections. No additional topic is needed for the parent heading.",
    "sec-2.2.1": "Section 2.2.1 ('Without Cause') is absent from the Exos standard form v1.0.0: Exos does not grant a mutual convenience-termination right in this agreement type. The anchor is registered in the form map to ensure the coverage gate flags any counterparty attempt to introduce such a clause; reviewers must create a REQUEST_CHANGE response if this section appears in a redline. Because the clause is intentionally absent, no standing topic is pre-loaded."
  },
  "sub_clause_splits": {
    "sec-10": {
      "description": "Issue #200: in the real (and SYNTHETIC placeholder) .docx, all four §10 sub-clauses live under ONE literal document heading ('Miscellaneous') -- there is no separate heading per sub-clause for the loader to match by heading text alone. 'source_heading' is that single real heading; 'splits' gives the ordered, document-order list of (anchor, marker) pairs the real-docx loader (scripts/diff_standard_form.py::_load_standard_form_paragraphs_from_docx) uses to partition the body paragraphs following that heading into the four sub-clause anchors, by matching each paragraph's leading lettered-paragraph marker. A paragraph with no marker is treated as a continuation of whichever split most recently matched.",
      "source_heading": "Miscellaneous",
      "splits": [
        {
          "anchor": "sec-10-notices",
          "marker": "(a)"
        },
        {
