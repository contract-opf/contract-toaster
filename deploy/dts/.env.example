# Copy to deploy/dts/.env and fill in. Used by docker-compose (--env-file).

# Required: secret used to sign demo session tokens (any long random string).
#   e.g. `openssl rand -hex 32`
DEMO_TOKEN_SECRET=change-me-to-a-long-random-string

# Required when MODEL_PROVIDER=openrouter (the default in both compose files):
# the real review pipeline calls OpenRouter and the client rejects an empty key,
# so every review fails (ERROR / MANUAL_REVIEW_REQUIRED) if this is unset — it
# does NOT fall back to the mock. Reviews are billed per model-policy/openrouter.json.
# Leave blank ONLY if you set MODEL_PROVIDER to a non-openrouter value to run the
# offline mock pipeline.
OPENROUTER_API_KEY=
