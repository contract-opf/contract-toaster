# Copy to deploy/dts/.env and fill in. Used by docker-compose (--env-file).

# Required: secret used to sign demo session tokens (any long random string).
#   e.g. `openssl rand -hex 32`
DEMO_TOKEN_SECRET=change-me-to-a-long-random-string

# Phase 2 only (real pipeline via OpenRouter). Not exercised by the Phase 1
# mock pipeline, so it can be left blank until then.
OPENROUTER_API_KEY=
